import { M3UPlaybackResolver } from '@/m3u/playback/M3UPlaybackResolver';
import type { PlayerSource } from '@/player/types';
import { MediaProvider } from '@/media/providers/MediaProvider';
import {
  UnifiedCategory,
  UnifiedCategoryMediaRequest,
  UnifiedCategoryRequest,
  UnifiedHomeFeed,
  UnifiedMediaItem,
  UnifiedPage,
  UnifiedSearchRequest,
} from '@/media/types';
import { M3URepository } from '@/m3u/repositories/M3URepository';
import { M3UCategory, M3UStreamMetadata } from '@/m3u/types';

const page = <T>(items: T[], limit: number, cursor?: string): UnifiedPage<T> => {
  const offset = cursor ? Number(cursor) : 0;
  const nextOffset = offset + limit;
  return { items: items.slice(offset, nextOffset), nextCursor: nextOffset < items.length ? String(nextOffset) : undefined, totalEstimate: items.length };
};

export class M3UProvider implements MediaProvider {
  readonly kind = 'm3u' as const;

  constructor(private readonly repository: M3URepository) {}

  async listCategories(request: UnifiedCategoryRequest): Promise<UnifiedPage<UnifiedCategory>> {
    if (!request.playlistId) return { items: [] };
    const result = await this.repository.listCategories({ playlistId: request.playlistId, limit: request.limit, cursor: request.cursor, signal: request.signal });
    return { ...result, items: result.items.map((category) => this.mapCategory(category)) };
  }

  async listMediaByCategory(request: UnifiedCategoryMediaRequest): Promise<UnifiedPage<UnifiedMediaItem>> {
    const result = await this.repository.listStreamsByCategory({
      playlistId: request.playlistId,
      categoryId: request.categoryId,
      limit: request.limit,
      cursor: request.cursor,
      forceRefresh: request.forceRefresh,
      signal: request.signal,
    });
    return { ...result, items: result.items.map((item) => this.mapStream(item)) };
  }

  async search(request: UnifiedSearchRequest): Promise<UnifiedPage<UnifiedMediaItem>> {
    if (!request.playlistId) return { items: [] };
    const categories = await this.listCategories({ playlistId: request.playlistId, limit: 30, signal: request.signal });
    const query = request.query.trim().toLowerCase();
    const pages = await Promise.all(categories.items.slice(0, 8).map((category) => this.listMediaByCategory({
      playlistId: category.playlistId,
      providerKind: 'm3u',
      categoryId: category.id,
      limit: 100,
      signal: request.signal,
    })));
    const matches = pages.flatMap((result) => result.items).filter((item) => item.searchText.includes(query));
    return page(matches, request.limit, request.cursor);
  }

  async getHomeFeed(playlistId?: string): Promise<UnifiedHomeFeed> {
    if (!playlistId) return { rows: [], generatedAt: new Date().toISOString() };
    const categories = await this.listCategories({ playlistId, limit: 8 });
    const rows = await Promise.all(categories.items.slice(0, 5).map(async (category) => {
      const media = await this.listMediaByCategory({ playlistId, providerKind: 'm3u', categoryId: category.id, limit: 12 });
      return { id: `m3u:${category.id}`, title: category.title, kind: 'channel' as const, providerKind: 'm3u' as const, playlistId, categoryId: category.id, items: media.items, nextCursor: media.nextCursor };
    }));
    return { hero: rows[0]?.items[0], rows, generatedAt: new Date().toISOString() };
  }

  private mapCategory(category: M3UCategory): UnifiedCategory {
    return {
      id: category.id,
      playlistId: category.playlistId,
      providerKind: 'm3u',
      title: category.title,
      kind: 'channel',
      itemCountEstimate: category.itemCountEstimate,
      sortOrder: category.sortOrder,
      updatedAt: category.updatedAt,
    };
  }

  private mapStream(stream: M3UStreamMetadata): UnifiedMediaItem {
    const base = {
      id: `m3u:${stream.playlistId}:${stream.id}`,
      playlistId: stream.playlistId,
      providerKind: 'm3u' as const,
      categoryId: stream.categoryId,
      title: stream.title,
      posterUrl: stream.logoUrl,
      backdropUrl: stream.logoUrl,
      provider: { providerKind: 'm3u' as const, playlistId: stream.playlistId, externalId: stream.id, categoryId: stream.categoryId },
      searchText: `${stream.title} ${stream.groupTitle} ${stream.tvgName ?? ''}`.toLowerCase(),
      updatedAt: stream.updatedAt,
    };
    if (stream.kind === 'movie') return { ...base, kind: 'movie' };
    if (stream.kind === 'series') return { ...base, kind: 'series' };
    return { ...base, kind: 'channel', isLive: true, streamUrl: stream.url, logoUrl: stream.logoUrl };
  }
}
