{
  "name": "premium-iptv-ui",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "start:dev": "APP_ENV=development EXPO_PUBLIC_APP_ENV=development expo start",
    "start:staging": "APP_ENV=staging EXPO_PUBLIC_APP_ENV=staging expo start",
    "start:prod": "APP_ENV=production EXPO_PUBLIC_APP_ENV=production expo start --no-dev --minify",
    "eas:build:android:preview": "eas build --platform android --profile staging",
    "eas:build:android:prod": "eas build --platform android --profile production",
    "eas:build:ios:prod": "eas build --platform ios --profile production",
    "eas:build:all:prod": "eas build --platform all --profile production",
    "expo:config:prod": "APP_ENV=production EXPO_PUBLIC_APP_ENV=production expo config"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "expo": "~52.0.0",
    "expo-blur": "~14.0.1",
    "expo-haptics": "~14.0.0",
    "expo-linear-gradient": "~14.0.2",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "expo-image": "~2.0.3",
    "expo-secure-store": "~14.0.0",
    "expo-av": "~15.0.2"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "^5.3.3"
  }
}
